# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
*.local

# Tauri / Rust
src-tauri/target/
src-tauri/gen/

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Local databases (never commit research data)
*.db
*.sqlite
*.sqlite3

# Internal / personal working documents (kept local, not published).
# All internal working docs now live in project-docs/ (handoff, requirements,
# project memory, initial prompt, and any future notes).
project-docs/
# Filename patterns kept as a safety net in case a doc is created outside that folder.
PROJECT_MEMORY.md
PRODUCT_REQUIREMENTS.md
CONVERSATION_AND_CODEBASE_HANDOFF.txt
initial_prompt.txt

# Generated sample/test data (regenerate with scripts/) + personal dev launcher
sample-data/
run-app.cmd

# Bundled sample dataset (seed DB + images) for test builds — not committed
src-tauri/seed/

# Python bytecode cache
__pycache__/
*.pyc

# Updater signing keys (PRIVATE — never commit; store in CI secrets)
.tauri/
src-tauri/.tauri/
*.key
